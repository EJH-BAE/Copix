# Required — Copix Studio sends this as Bearer token
COPIX_API_KEY=change-me-to-a-long-random-string

# Backend: ollama (recommended) | huggingface
BACKEND=ollama

# --- Ollama backend (run Ollama on a VPS, point proxy at it) ---
OLLAMA_URL=http://your-vps-ip:11434
DEFAULT_MODEL=gpt-oss:20b

# --- Hugging Face backend (no 20B on free VPS; uses HF credits/limits) ---
# HF_TOKEN=hf_...
# HF_MODEL=openai/gpt-oss-20b

RATE_LIMIT_PER_MIN=30
PORT=8080
